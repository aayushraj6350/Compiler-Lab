# Write a python program to simulate lexical analyzer for validating operators.


operators = ['+', '-', '*', '/', '=']
keywords = ['if', 'else', 'while', 'for', 'int']

exp = input("Enter an expression: ")

tokens = exp.split()

for token in tokens:
    
    if token in operators:
        print(token, "is an Operator")
        
    elif token in keywords:
        print(token, "is a Keyword")
        
    elif token.isdigit():
        print(token, "is a Number")
        
    else:
        print(token, "is an Identifier")
